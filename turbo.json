{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json"],
  "globalPassThroughEnv": ["CI"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "_build": {
      "dependsOn": ["^_build", "_typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "!.turbo/**"],
      "outputs": ["dist/**"]
    },
    "_typecheck": {
      "dependsOn": ["^_build"],
      "inputs": ["$TURBO_DEFAULT$", "!.turbo/**"]
    },
    "_lint": {
      "dependsOn": ["^_build"],
      "inputs": ["$TURBO_DEFAULT$", "!.turbo/**"]
    },
    "_test": {
      "dependsOn": ["_build"],
      "inputs": ["$TURBO_DEFAULT$", "!.turbo/**"]
    }
  }
}
