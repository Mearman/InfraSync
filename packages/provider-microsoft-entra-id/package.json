{
  "name": "@infrasync-org/microsoft-entra-id",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "_build": "tsdown",
    "_typecheck": "tsc -p tsconfig.json --noEmit",
    "_lint": "eslint . --cache",
    "_test": "node --import tsx --test 'src/__tests__/*.int.test.ts'"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/identity-cache-persistence": "1.3.0",
    "@microsoft/microsoft-graph-client": "3.0.7",
    "@microsoft/microsoft-graph-types": "2.43.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@infrasync-org/core": "workspace:*"
  },
  "devDependencies": {
    "@infrasync-org/core": "workspace:*",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
