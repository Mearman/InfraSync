{
  "name": "aliased-provider",
  "providers": [
    {
      "key": "cf-prod",
      "adapterName": "cloudflare",
      "config": {
        "apiToken": { "$secret": { "kind": "env", "name": "CF_PROD_TOKEN" } }
      }
    },
    {
      "key": "cf-staging",
      "adapterName": "cloudflare",
      "config": {
        "apiToken": { "$secret": { "kind": "env", "name": "CF_STAGING_TOKEN" } }
      }
    }
  ],
  "resources": [
    {
      "name": "prod-record",
      "provider": "cf-prod",
      "kind": "DnsRecord",
      "mode": "manage",
      "spec": {
        "kind": "DnsRecord",
        "zoneId": "zone-prod",
        "type": "A",
        "name": "prod.example.com",
        "content": "1.2.3.4"
      },
      "dependsOn": []
    },
    {
      "name": "staging-record",
      "provider": "cf-staging",
      "kind": "DnsRecord",
      "mode": "manage",
      "spec": {
        "kind": "DnsRecord",
        "zoneId": "zone-staging",
        "type": "A",
        "name": "staging.example.com",
        "content": "5.6.7.8"
      },
      "dependsOn": []
    }
  ]
}
