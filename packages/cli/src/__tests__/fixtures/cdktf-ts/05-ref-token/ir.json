{
  "name": "ref-token",
  "providers": [
    {
      "key": "cf",
      "adapterName": "cloudflare",
      "config": {}
    }
  ],
  "resources": [
    {
      "name": "zone",
      "provider": "cf",
      "kind": "Zone",
      "mode": "manage",
      "spec": {
        "kind": "Zone",
        "name": "example.com",
        "zoneId": "auto-generated"
      },
      "dependsOn": []
    },
    {
      "name": "record",
      "provider": "cf",
      "kind": "DnsRecord",
      "mode": "manage",
      "spec": {
        "kind": "DnsRecord",
        "zoneId": { "$ref": { "resource": "zone", "path": "zoneId" } },
        "type": "A",
        "name": "www.example.com",
        "content": "1.2.3.4"
      },
      "dependsOn": []
    }
  ]
}
