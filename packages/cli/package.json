{
  "name": "@infrasync-org/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "infrasync": "./bin/infrasync.mjs"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "_build": "tsdown",
    "_typecheck": "tsc -p tsconfig.json --noEmit",
    "_lint": "eslint . --cache",
    "_test": "node --import tsx --test 'src/__tests__/*.int.test.ts'"
  },
  "dependencies": {
    "@infrasync-org/adapter-terraform-config-json": "workspace:*",
    "@infrasync-org/adapter-terraform-show-json": "workspace:*",
    "@infrasync-org/core-ir": "workspace:*",
    "@infrasync-org/migration-planner": "workspace:*",
    "jiti": "2.6.1"
  },
  "peerDependencies": {
    "@infrasync-org/core": "workspace:*"
  },
  "devDependencies": {
    "@infrasync-org/core": "workspace:*",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
