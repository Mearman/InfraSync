{
  "name": "@infrasync/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "infrasync": "./bin/infrasync.mjs"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "_build": "tsdown",
    "_typecheck": "tsc -p tsconfig.json --noEmit",
    "_lint": "eslint . --cache"
  },
  "dependencies": {
    "jiti": "2.6.1"
  },
  "peerDependencies": {
    "@infrasync/core": "workspace:*"
  },
  "devDependencies": {
    "@infrasync/core": "workspace:*",
    "tsdown": "0.21.7",
    "typescript": "6.0.3"
  }
}
