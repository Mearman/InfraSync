{
  "name": "@infrasync/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "infrasync": "./bin/infrasync.mjs"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --cache"
  },
  "dependencies": {
    "jiti": "2.6.1"
  },
  "peerDependencies": {
    "@infrasync/core": "workspace:*"
  },
  "devDependencies": {
    "@infrasync/core": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  }
}
